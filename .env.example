OS=debian
PBX=FreePBX
# With network_mode: host the container shares the host's network stack.
# Use 127.0.0.1 (localhost) for all services running on the PBX host.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=OpDesk
DB_PASSWORD=change_me
DB_NAME=asterisk
DB_CDR=asteriskcdrdb
DB_OpDesk=OpDesk

ASTERISK_RECORDING_ROOT_DIR=/var/spool/asterisk/monitor/
AMI_HOST=127.0.0.1
AMI_PORT=5038
AMI_USERNAME=OpDesk
AMI_SECRET=change_me
AMI_CONTEXT=ext-local

PORT=8765
OPDESK_HTTPS_PORT=8443
JWT_SECRET=change_me_to_a_long_random_string

OPDESK_BIND_HOST=127.0.0.1
OPDESK_DOMAIN=op-desk.com
CORS_ALLOWED_ORIGINS=https://op-desk.com,https://207.231.111.34


# IMPORTANT: these are the names server.py reads:
HTTPS_CERT=/opt/opdesk/cert/opdesk_cert.pem
HTTPS_KEY=/opt/opdesk/cert/opdesk_key.pem

# --- Mobile push notifications (optional) ---
# Leave these unset to disable push (web client is unaffected). A provider is skipped
# unless all of its vars are present. Mount the key files as secrets; never commit them.
# Android — Firebase Cloud Messaging (HTTP v1):
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_FILE=/opt/OpDesk/secrets/fcm-service-account.json
# iOS — direct APNs (HTTP/2, token-based auth). VoIP topic is <APNS_BUNDLE_ID>.voip:
APNS_AUTH_KEY_FILE=/opt/OpDesk/secrets/AuthKey_XXXX.p8
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_USE_SANDBOX=false
# Seconds the dialplan waits after sending the wake push (gives the app time to re-register):
MOBILE_WAKE_WAIT=3
